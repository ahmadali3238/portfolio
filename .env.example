# Local environment template for Ahmad Ali — Portfolio + Job Finder
# Copy this to .env.local and fill in the real values.
# EVERYTHING here is optional — the portfolio runs and builds with NO keys at all.
# Add a section only when you want to switch that feature on.

# General Next.js environment
NODE_ENV=development

# Public site URL (used by SEO, the /r tracking redirect, sitemap, etc.)
NEXT_PUBLIC_SITE_URL=https://ahmadali3238.vercel.app

# ───────────────────────── AI chat assistant (optional) ─────────────────────────
# WITHOUT a key the assistant still works using a built-in offline knowledge base.
# Add a free Groq key to upgrade to full LLM answers. (Also used by the Job Finder.)
GROQ_API_KEY=your-groq-api-key

# ───────────────────────── Contact form (optional) ─────────────────────────
# The contact form sends mail straight from the browser via EmailJS.
# Create a free EmailJS service + template pointed at Ahmad's inbox, then set these.
# Template variables must be: from_name, user_email, message, reply_to, date.
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your-emailjs-service-id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your-emailjs-template-id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your-emailjs-public-key

# ───────────────────────── Voice on the assistant (optional) ─────────────────────────
# Without a key the assistant falls back to the browser's built-in speech.
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# ───────────────────────── Admin dashboard + Job Finder (optional) ─────────────────────────
# Needed only if you want the /admin Job Finder dashboard + the automation pipeline.
# Supabase stores the discovered jobs, drafts, and replies.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Admin login (protects /admin)
ADMIN_EMAIL=your-admin-email@example.com
# Use either ADMIN_PASSWORD or ADMIN_PASSWORD_HASH (run `pnpm hash:admin-password`).
ADMIN_PASSWORD=your-plain-password
# ADMIN_PASSWORD_HASH=scrypt$<salt>$<hash>
ADMIN_SESSION_SECRET=your-admin-session-secret

# ───────────────────────── Job Finder automation (optional) ─────────────────────────
# Operational settings (keywords, target countries, sources, send mode) live in the
# committed file scripts/outreach/outreach.config.json — edit that, not here.
# Only SECRETS / API keys go here. Each job source fails soft if its key is absent.
#
# Free UAE/GCC job APIs (sign up for the free tiers):
JSEARCH_API_KEY=your-jsearch-or-rapidapi-key   # JSearch (OpenWeb Ninja / RapidAPI) — Google-for-Jobs, country=ae
CAREERJET_AFFID=your-careerjet-affiliate-id    # Careerjet public API, locale en_AE
JOOBLE_API_KEY=your-jooble-api-key             # Jooble REST API (33k+ UAE vacancies)
#
# Email digest of new matches + (optional) draft sending:
RESEND_API_KEY=your-resend-api-key             # emails Ahmad the daily digest of new jobs
RESEND_FROM_EMAIL=Job Finder <noreply@yourdomain.com>
GMAIL_APP_PASSWORD=your-gmail-app-password     # only if you switch send mode away from "draft"
#
# Safety: the pipeline defaults to dry-run + "draft" mode (nothing is auto-sent).
# OUTREACH_DRY_RUN=0
